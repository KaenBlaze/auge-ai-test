# Paths
DATA_DIR=./data
DOCUMENTS_DIR=./data/documents
FAISS_INDEX_DIR=./storage/faiss_index
GOLDEN_SEED_PATH=./data/golden_set.jsonl
HISTORICAL_RESULTS_PATH=./data/historical_results.csv

# Embeddings (local sentence-transformers; BGE preferred)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# Chunking (token counts)
CHUNK_SIZE=640
CHUNK_OVERLAP=100

# Retrieval
TOP_K_RETRIEVE=10
TOP_K_RERANK=5
SIMILARITY_THRESHOLD=0.3

# Reranker (local cross-encoder; BGE preferred)
RERANKER_MODEL=BAAI/bge-reranker-base
USE_RERANKER=true

# Generator (local open-weight models; choose one backend)
MODEL_BACKEND=ollama
# Ollama tag uses a colon, e.g. qwen2.5:7b (not qwen2.5-7b)
MODEL_NAME=qwen2.5:7b
GENERATOR_TEMPERATURE=0.1
GENERATOR_MAX_TOKENS=512

# Ollama backend
# Local dev: http://localhost:11434
# Docker Compose: http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PULL_MODEL=true

# vLLM OpenAI-compatible backend
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY

# Hugging Face Transformers backend
TRANSFORMERS_DEVICE=cpu
TRANSFORMERS_TORCH_DTYPE=auto

# Confidence / abstention
CONFIDENCE_THRESHOLD=0.45
MIN_RETRIEVAL_SCORE=0.30
MIN_RERANK_SCORE=0.20
MIN_SUPPORTING_CHUNKS=1
MIN_CITATION_SUPPORT=0.20
MIN_FRAGMENT_AGREEMENT=0.0
REQUIRE_CITATIONS=false
ABSTAIN_ON_LOW_CONFIDENCE=true

# API
API_HOST=0.0.0.0
API_PORT=8000
