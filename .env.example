# Paths
DATA_DIR=./data
DOCUMENTS_DIR=./data/documents
VECTOR_STORE_DIR=./data/vector_store
GOLDEN_SEED_PATH=./data/golden_seed.jsonl
HISTORICAL_RESULTS_PATH=./data/historical_results.csv

# Embeddings (local sentence-transformers model)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Chunking (token counts)
CHUNK_SIZE=640
CHUNK_OVERLAP=100

# Retrieval
TOP_K_RETRIEVE=10
TOP_K_RERANK=5
SIMILARITY_THRESHOLD=0.3

# Reranker (local cross-encoder)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
USE_RERANKER=true

# Generator (local LLM via Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
GENERATOR_TEMPERATURE=0.1
GENERATOR_MAX_TOKENS=512

# Confidence / abstention
CONFIDENCE_THRESHOLD=0.5
ABSTAIN_ON_LOW_CONFIDENCE=true

# API
API_HOST=0.0.0.0
API_PORT=8000
